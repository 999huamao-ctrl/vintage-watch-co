generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户系统
model User {
  id          String    @id @default(uuid())
  username    String    @unique
  email       String    @unique
  password    String    // hashed
  role        UserRole  @default(CUSTOMER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  isActive    Boolean   @default(true)
  
  // Relations
  orders      Order[]
  activities  UserActivity[]
  
  @@map("users")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  SUPPLY
  LOGISTICS
  CUSTOMER
}

// 商品系统
model Product {
  id            String   @id @default(uuid())
  name          String
  nameZh        String?  // 中文名称
  nameDe        String?  // 德语名称
  nameFr        String?  // 法语名称
  nameEs        String?  // 西班牙语名称
  nameIt        String?  // 意大利语名称
  nameJa        String?  // 日语名称
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  category      String
  description   String   @db.Text
  descriptionZh String?  @db.Text
  image         String
  images        String[] // 多图
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // 规格
  caseSize      String?
  movement      String?
  strap         String?
  waterResistance String?
  
  // Relations
  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]
  
  @@map("products")
}

// 订单系统
model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  
  // 客户信息
  customerName    String
  customerEmail   String
  customerPhone   String?
  
  // 收货地址
  shippingAddress String
  shippingCity    String
  shippingZip     String
  shippingCountry String
  
  // 支付信息
  paymentMethod   String      @default("USDT")
  paymentStatus   PaymentStatus @default(PENDING)
  paymentTxHash   String?     // USDT交易哈希
  
  // 金额
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  
  // 物流
  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  // UTM归因
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  
  // Relations
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  items           OrderItem[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@map("orders")
}

enum OrderStatus {
  PENDING       // 待处理
  CONFIRMED     // 已确认
  PROCESSING    // 处理中
  SHIPPED       // 已发货
  DELIVERED     // 已送达
  CANCELLED     // 已取消
  REFUNDED      // 已退款
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  
  @@map("order_items")
}

// 供应商管理
model Supplier {
  id          String    @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  purchaseOrders PurchaseOrder[]
  
  @@map("suppliers")
}

// 采购单
model PurchaseOrder {
  id           String    @id @default(uuid())
  poNumber     String    @unique
  supplierId   String
  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  status       POStatus  @default(DRAFT)
  totalAmount  Decimal   @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime  @default(now())
  receivedAt   DateTime?
  
  items        PurchaseOrderItem[]
  
  @@map("purchase_orders")
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  SHIPPED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id          String        @id @default(uuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productName String
  quantity    Int
  unitPrice   Decimal       @db.Decimal(10, 2)
  totalPrice  Decimal       @db.Decimal(10, 2)
  
  @@map("purchase_order_items")
}

// 库存流水
model InventoryLog {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        String   // IN (入库), OUT (出库), ADJUST (调整)
  quantity    Int
  reason      String   // purchase, sale, return, adjustment
  referenceId String?  // 关联订单ID或采购单ID
  note        String?
  createdAt   DateTime @default(now())
  
  @@map("inventory_logs")
}

// 广告活动
model AdCampaign {
  id          String   @id @default(uuid())
  name        String
  platform    String   // facebook, google, tiktok
  status      String   // active, paused, ended
  budget      Decimal  @db.Decimal(10, 2)
  spend       Decimal  @default(0) @db.Decimal(10, 2)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  startDate   DateTime
  endDate     DateTime?
  utmCampaign String?
  createdAt   DateTime @default(now())
  
  @@map("ad_campaigns")
}

// 运营日报
model DailyReport {
  id          String   @id @default(uuid())
  date        DateTime @unique
  revenue     Decimal  @db.Decimal(10, 2)
  orders      Int
  visitors    Int
  adSpend     Decimal  @db.Decimal(10, 2)
  newCustomers Int
  note        String?
  createdAt   DateTime @default(now())
  
  @@map("daily_reports")
}

// 用户行为追踪
model UserActivity {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String
  action    String   // view_product, add_cart, checkout_start, purchase
  productId String?
  metadata  Json?    // 额外数据
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  
  @@map("user_activities")
}

// 钱包配置
model WalletConfig {
  id          String   @id @default(uuid())
  l1Receiving String   // 收款钱包
  l2Operating String   // 运营钱包
  l3Profit    String   // 利润钱包
  updatedAt   DateTime @updatedAt
  updatedBy   String
  
  @@map("wallet_config")
}
