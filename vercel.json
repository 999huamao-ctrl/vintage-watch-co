{
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin/(.*)", "dest": "/admin.html" },
    { "src": "/shop", "dest": "/shop.html" },
    { "src": "/product/([^/]+)", "dest": "/product/[id].html" },
    { "src": "/checkout", "dest": "/checkout.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
